# Skopiuj na serwer jako apps/api/.env (nie commituj prawdziwego .env).
# Używaj tylko zwykłych znaków ASCII w URL — bez „…” (wielokropka Unicode).

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME"

# Frontend (CORS / cookies) — na produkcji ustaw dokładnie origin aplikacji:
# FRONTEND_ORIGIN=https://fuckupmanager.lamastage.pl

# Linki w mailach (zaproszenie, reset hasła). W produkcji wymagane przy NODE_ENV=production:
# APP_BASE_URL_PROD=https://fuckupmanager.lamastage.pl

# Wysyłka maili (zaproszenia użytkowników, reset hasła). Bez tego zaproszenia zwracają błąd:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=twoje-haslo
# SMTP_FROM="Lama Stage <noreply@example.com>"
# Opcjonalne limity czasu (ms) — bez tego zły host/port mógł wisieć bez końca:
# SMTP_CONNECT_TIMEOUT_MS=20000
# SMTP_READ_TIMEOUT_MS=25000

# Opcjonalnie (seed / smoke):
# SEED_ADMIN_EMAIL=biuro@example.pl
# SEED_ADMIN_PASSWORD=zmien-to
# NODE_ENV=production
# PORT=3000

# Development — linki w mailach jeśli nie ustawisz APP_BASE_URL_PROD:
# APP_BASE_URL=http://localhost:5173
