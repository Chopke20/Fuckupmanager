{
  "name": "@lama-stage/api",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --prefer-ts-exts src/index.ts",
    "build": "prisma generate --schema prisma/schema.prisma && tsc && node scripts/copy-pdf-templates.cjs",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:seed": "ts-node src/prisma/seed.ts",
    "db:normalize-codes": "ts-node scripts/normalize-internal-codes.ts",
    "db:migrate-legacy-codes": "ts-node scripts/migrate-legacy-codes.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@lama-stage/shared-types": "*",
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.0",
    "helmet": "^7.1.0",
    "puppeteer": "^22.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
